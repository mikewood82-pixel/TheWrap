# Cloudflare Pages cache headers
# Newsletter images are content-addressed-ish (per-edition folder) and
# never change after publish — safe to cache for a year at the edge.
/newsletters/*
  Cache-Control: public, max-age=31536000, immutable

# Same for static visual assets
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
