# Cloudflare Pages cache headers
#
# Newsletter images REUSE filenames (image1.webp, image2.webp, ...) across the
# Thu->Fri publish window and during image re-map fixes, so they are NOT
# immutable. Serve fast from cache but revalidate so a swapped image can never
# stick at the edge for more than a few minutes (a max-age=1yr+immutable header
# stranded the wrong "Salt in the Eyes" images at the edge on 2026-05-28).
#
# IMPORTANT: do NOT add global extension globs like /*.webp here. Cloudflare
# MERGES every matching rule's Cache-Control, so a /*.webp immutable rule would
# re-add immutable+max-age=1yr to /newsletters/** even with the rule below.
# Long-cache assets must therefore be listed by explicit path, never by glob.
/newsletters/*
  Cache-Control: public, max-age=300, stale-while-revalidate=2592000

# Vite build output is content-hashed (index-<hash>.js etc.) -> safe immutable.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static brand/site assets in public/ root. These never get their bytes
# swapped under the same filename, so a long immutable cache is safe.
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
/icon.png
  Cache-Control: public, max-age=31536000, immutable
/icons.svg
  Cache-Control: public, max-age=31536000, immutable
/logo.png
  Cache-Control: public, max-age=31536000, immutable
/wrap-mascot.png
  Cache-Control: public, max-age=31536000, immutable
/mike-wood.jpg
  Cache-Control: public, max-age=31536000, immutable
/og-default.png
  Cache-Control: public, max-age=31536000, immutable

# Sponsor logos — listed by explicit path (never a glob, per the warning above).
# Immutable is safe because a new sponsor/logo ships under a new filename rather
# than overwriting an existing one at the edge.
/sponsors/perfecthire.webp
  Cache-Control: public, max-age=31536000, immutable
